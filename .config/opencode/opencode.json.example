{
  "$schema": "https://opencode.ai/config.json",
  "model": "your-provider/your-model",
  "provider": {
    "your-provider": {
      "api": "openai-completions",
      "name": "Your Provider",
      "models": {
        "your-model": {
          "id": "your-model",
          "name": "Your Model",
          "reasoning": false,
          "tool_call": true
        }
      },
      "options": {
        "apiKey": "your-api-key-here",
        "baseURL": "https://your-api-endpoint.com/v2/coding"
      }
    }
  }
}
